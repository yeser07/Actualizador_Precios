@{
    ViewData["Title"] = "Inicio";
}

<section class="home-welcome" aria-labelledby="home-welcome-title">
    <div class="home-welcome__shell">
        <div class="home-welcome__glow home-welcome__glow--1" aria-hidden="true"></div>
        <div class="home-welcome__glow home-welcome__glow--2" aria-hidden="true"></div>

        <div class="home-welcome__card">
            <div class="home-welcome__ribbon" aria-hidden="true"></div>

            <div class="home-welcome__brand">
                <span class="home-welcome__logo" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                    </svg>
                </span>
                <span class="home-welcome__brand-text">Pets Planet</span>
            </div>

            <h1 id="home-welcome-title" class="home-welcome__title">
                Bienvenido al Actualizador de Precios
            </h1>

            <p class="home-welcome__lead">
                Este actualizador está enlazado a la base de datos de Aspel SAE.
            </p>

            <div class="home-welcome__cta">
                <a class="btn btn-primary btn-lg home-welcome__btn" asp-controller="AlertaCambioCosto" asp-action="Index">
                    Ir a alertas de costo
                </a>
                <p class="home-welcome__cta-note">
                    Revise cambios de costo y actualice precios por lista cuando lo necesite.
                </p>
            </div>

            <div class="home-welcome__divider" role="presentation"></div>

            <p class="home-welcome__credit">
                Proyecto desarrollado para <strong>Pets Planet</strong>
            </p>
        </div>
    </div>
</section>
